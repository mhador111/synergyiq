# MongoDB
# - Local dev: leave default OR point to your own
# - Production (Vercel): use MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/synergyiq

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string

# Public URL of the app
# - Local: http://localhost:3000
# - Vercel: https://<your-app>.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ===== App =====
NEXT_PUBLIC_APP_NAME="SynergyIQ"
